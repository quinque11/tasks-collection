#include <iostream>

using namespace std;

int sumDigits(int n) {
    return n / 100 + (n / 10) % 10 + n % 10;
}

void test() {
    cout << "Сумма цифр 345 = " << sumDigits(345) << endl;
}

int main() {
    int N;

    cout << "Введите сумму цифр: ";
    cin >> N;

    for (int i = 100; i <= 999; i++) {
        if (sumDigits(i) == N)
            cout << i << " ";
    }

    cout << endl;

    test();

    return 0;
}