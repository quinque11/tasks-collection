#include <iostream>
#include <string>

using namespace std;

string trim(string s) {
    while (!s.empty() && s.front() == ' ')
        s.erase(0, 1);

    while (!s.empty() && s.back() == ' ')
        s.pop_back();

    return s;
}

void test() {
    cout << "[" << trim("   hello world   ") << "]" << endl;
}

int main() {
    string s;

    cout << "Введите строку:\n";
    getline(cin, s);

    cout << "[" << trim(s) << "]" << endl;

    test();

    return 0;
}