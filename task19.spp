#include <iostream>

using namespace std;

void factor(int n, int d = 2) {
    if (n == 1)
        return;

    if (n % d == 0) {
        cout << d << " ";
        factor(n / d, d);
    } else {
        factor(n, d + 1);
    }
}

void test() {
    cout << "36 = ";
    factor(36);
    cout << endl;
}

int main() {
    int n;

    cout << "Введите число: ";
    cin >> n;

    cout << "Множители: ";
    factor(n);
    cout << endl;

    test();

    return 0;
}