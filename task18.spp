#include <iostream>

using namespace std;

double f(double x) {
    return x * x + 2 * x + 1;
}

double derivative(double x, double h = 0.0001) {
    return (f(x + h) - f(x - h)) / (2 * h);
}

void test() {
    cout << "f'(2) = " << derivative(2) << endl;
}

int main() {
    double x;

    cout << "Введите x: ";
    cin >> x;

    cout << "Производная = " << derivative(x) << endl;

    test();

    return 0;
}